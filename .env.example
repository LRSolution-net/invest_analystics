# ─────────────────────────────────────────────────────────────
# Supabase — public keys safe for the frontend
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key

# ─────────────────────────────────────────────────────────────
# Alpha Vantage — free tier API key
# https://www.alphavantage.co/support/#api-key
# ─────────────────────────────────────────────────────────────
VITE_ALPHA_VANTAGE_KEY=sua_alpha_vantage_key

# ─────────────────────────────────────────────────────────────
# Supabase service role key — ONLY for server-side scripts
# NEVER expose this in the React frontend!
# ─────────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
